{
  "name": "trackflow-dashboard-mac",
  "version": "1.0.0",
  "description": "TrackFlow Productivity Dashboard for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "author": "Varahe Analytics",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.varahe.trackflow",
    "productName": "TrackFlow Dashboard",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist"
    },
    "extraResources": [
      {
        "from": "bin/TrackFlowServer",
        "to": "server/TrackFlowServer"
      },
      {
        "from": "bin/TrackFlowAgent",
        "to": "server/TrackFlowAgent"
      }
    ],
    "files": [
      "main.js",
      "preload.js"
    ]
  }
}
