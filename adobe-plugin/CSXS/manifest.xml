<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="7.0" ExtensionBundleId="com.productivity.tracker" ExtensionBundleVersion="1.0.0"
		ExtensionBundleName="Productivity Tracker" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<ExtensionList>
		<Extension Id="com.productivity.tracker.panel" Version="1.0.0" />
	</ExtensionList>
	<ExecutionEnvironment>
		<HostList>
			<!-- Photoshop -->
			<Host Name="PHSP" Version="[15.0,99.9]" />
			<!-- Premiere Pro -->
			<Host Name="PPRO" Version="[9.0,99.9]" />
			<!-- After Effects -->
			<Host Name="AEFT" Version="[13.0,99.9]" />
			<!-- Illustrator -->
			<Host Name="ILST" Version="[18.0,99.9]" />
		</HostList>
		<LocaleList>
			<Locale Code="All" />
		</LocaleList>
		<RequiredRuntimeList>
			<RequiredRuntime Name="CSXS" Version="7.0" />
		</RequiredRuntimeList>
	</ExecutionEnvironment>
	<DispatchInfoList>
		<Extension Id="com.productivity.tracker.panel">
			<DispatchInfo>
				<Resources>
					<MainPath>./index.html</MainPath>
					<ScriptPath>./host.jsx</ScriptPath>
				</Resources>
				<Lifecycle>
					<AutoVisible>false</AutoVisible>
					<StartOn>
						<Event>com.adobe.csxs.events.ApplicationInitialized</Event>
					</StartOn>
				</Lifecycle>
				<UI>
					<Type>Custom</Type>
					<Menu>Productivity Tracker</Menu>
					<Geometry>
						<Size>
							<Height>1</Height>
							<Width>1</Width>
						</Size>
					</Geometry>
				</UI>
			</DispatchInfo>
		</Extension>
	</DispatchInfoList>
</ExtensionManifest>
